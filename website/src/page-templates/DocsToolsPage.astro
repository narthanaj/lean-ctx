      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_compress_memory'}><code>ctx_compress_memory</code></a></td><td>{t('docs.tools.intelligenceCompressMemoryDesc')}</td></tr>
    </tbody>
  </table>
  <p><a href={lp('/docs/tools/intelligence')}>{t('docs.tools.viewIntelligenceDocs')}</a></p>

  <hr />

