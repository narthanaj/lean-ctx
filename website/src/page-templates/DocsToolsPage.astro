---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.tools.sidebarCategories'),
    items: [
      { label: t('docs.tools.sidebarAllTools'), href: lp('/docs/tools') },
      { label: t('docs.tools.sidebarCore'), href: lp('/docs/tools') + '#core-tools' },
      { label: t('docs.tools.sidebarIntelligence'), href: lp('/docs/tools') + '#intelligence-engine' },
      { label: t('docs.tools.sidebarSession'), href: lp('/docs/tools') + '#session-monitoring' },
      { label: t('docs.tools.sidebarMemory'), href: lp('/docs/tools') + '#persistent-memory-multi-agent' },
    ],
  },
  {
    title: t('docs.tools.sidebarDeepDives'),
    compact: true,
    items: [
      { label: t('docs.tools.sidebarCoreTools'), href: lp('/docs/tools/core') },
      { label: t('docs.tools.sidebarIntelligenceTools'), href: lp('/docs/tools/intelligence') },
      { label: t('docs.tools.sidebarSessionTools'), href: lp('/docs/tools/session') },
      { label: t('docs.tools.sidebarMemoryTools'), href: lp('/docs/tools/memory') },
    ],
  },
  {
    title: t('docs.common.related'),
    items: [
      { label: t('nav.docs.analytics'), href: lp('/docs/analytics') },
      { label: t('nav.docs.cliComplete'), href: lp('/docs/cli-reference') },
      { label: t('nav.docs.quickReference'), href: lp('/docs/quick-reference') },
      { label: t('nav.docs.tokenGuide'), href: lp('/docs/token-guide') },
      { label: t('nav.docs.treeSitter'), href: lp('/docs/tree-sitter') },
    ],
  },
];
---

<DocsLayout title={t('docs.tools.title')} description={t('docs.tools.description')} sidebar={sidebar}>
  <p>{t('docs.tools.intro')}</p>

  <h2 id="core-tools">{t('docs.tools.coreTitle')}</h2>
  <p>{t('docs.tools.coreDesc')}</p>
  <table>
    <thead>
      <tr><th>{t('docs.tools.thTool')}</th><th>{t('docs.tools.thWhatItDoes')}</th><th>{t('docs.tools.thSavings')}</th></tr>
    </thead>
    <tbody>
      <tr><td><a href={lp('/docs/tools/core') + '#ctx_read'}><code>ctx_read</code></a></td><td>{t('docs.tools.coreReadDesc')}</td><td>up to 99%</td></tr>
      <tr><td><a href={lp('/docs/tools/core') + '#ctx_multi_read'}><code>ctx_multi_read</code></a></td><td>{t('docs.tools.coreMultiReadDesc')}</td><td>{t('docs.tools.coreMultiReadSavings')}</td></tr>
      <tr><td><a href={lp('/docs/tools/core') + '#ctx_tree'}><code>ctx_tree</code></a></td><td>{t('docs.tools.coreTreeDesc')}</td><td>34-60%</td></tr>
      <tr><td><a href={lp('/docs/tools/core') + '#ctx_shell'}><code>ctx_shell</code></a></td><td set:html={t('docs.tools.coreShellDesc')} /></tr>
      <tr><td><a href={lp('/docs/tools/core') + '#ctx_search'}><code>ctx_search</code></a></td><td>{t('docs.tools.coreSearchDesc')}</td><td>50-80%</td></tr>
    </tbody>
  </table>
  <p><a href={lp('/docs/tools/core')}>{t('docs.tools.viewCoreDocs')}</a></p>

  <hr />

  <h2 id="intelligence-engine">{t('docs.tools.intelligenceTitle')}</h2>
  <p>{t('docs.tools.intelligenceDesc')}</p>
  <table>
    <thead>
      <tr><th>{t('docs.tools.thTool')}</th><th>{t('docs.tools.thWhatItDoes')}</th></tr>
    </thead>
    <tbody>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_smart_read'}><code>ctx_smart_read</code></a></td><td>{t('docs.tools.intelligenceSmartReadDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_delta'}><code>ctx_delta</code></a></td><td>{t('docs.tools.intelligenceDeltaDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_fill'}><code>ctx_fill</code></a></td><td>{t('docs.tools.intelligenceFillDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_intent'}><code>ctx_intent</code></a></td><td>{t('docs.tools.intelligenceIntentDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_context'}><code>ctx_context</code></a></td><td>{t('docs.tools.intelligenceContextDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_graph'}><code>ctx_graph</code></a></td><td>{t('docs.tools.intelligenceGraphDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_dedup'}><code>ctx_dedup</code></a></td><td>{t('docs.tools.intelligenceDedupDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_response'}><code>ctx_response</code></a></td><td>{t('docs.tools.intelligenceResponseDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_discover'}><code>ctx_discover</code></a></td><td>{t('docs.tools.intelligenceDiscoverDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_edit'}><code>ctx_edit</code></a></td><td>{t('docs.tools.intelligenceEditDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_preload'}><code>ctx_preload</code></a></td><td>{t('docs.tools.intelligencePreloadDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_semantic_search'}><code>ctx_semantic_search</code></a></td><td>{t('docs.tools.intelligenceSemanticSearchDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_symbol'}><code>ctx_symbol</code></a></td><td>{t('docs.tools.intelligenceSymbolDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_outline'}><code>ctx_outline</code></a></td><td>{t('docs.tools.intelligenceOutlineDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_callers'}><code>ctx_callers</code></a></td><td>{t('docs.tools.intelligenceCallersDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/intelligence') + '#ctx_callees'}><code>ctx_callees</code></a></td><td>{t('docs.tools.intelligenceCalleesDesc')}</td></tr>
