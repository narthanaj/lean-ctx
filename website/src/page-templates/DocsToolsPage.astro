    </thead>
    <tbody>
      <tr><td><a href={lp('/docs/tools/session') + '#ctx_session'}><code>ctx_session</code></a></td><td>{t('docs.tools.sessionSessionDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/session') + '#ctx_compress'}><code>ctx_compress</code></a></td><td>{t('docs.tools.sessionCompressDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/session') + '#ctx_analyze'}><code>ctx_analyze</code></a></td><td>{t('docs.tools.sessionAnalyzeDesc')}</td></tr>
