  <table>
    <thead>
      <tr><th>{t('docs.tools.thTool')}</th><th>{t('docs.tools.thWhatItDoes')}</th></tr>
    </thead>
    <tbody>
      <tr><td><a href={lp('/docs/tools/memory') + '#ctx_knowledge'}><code>ctx_knowledge</code></a></td><td>{t('docs.tools.memoryKnowledgeDesc')}</td></tr>
      <tr><td><a href={lp('/docs/tools/memory') + '#ctx_agent'}><code>ctx_agent</code></a></td><td>{t('docs.tools.memoryAgentDesc')}</td></tr>
