---
const sections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs/getting-started' },
      { label: 'Installation', href: '/docs/installation' },
      { label: 'Quick Start', href: '/docs/quick-start' },
    ],
  },
  {
    title: 'Tools',
    items: [
      { label: 'ctx_read', href: '/docs/tools' },
      { label: 'ctx_tree', href: '/docs/tools-tree' },
      { label: 'ctx_shell', href: '/docs/tools-shell' },
      { label: 'ctx_search', href: '/features#ctx_search' },
      { label: 'ctx_compress', href: '/features#ctx_compress' },
      { label: 'ctx_analyze', href: '/features#ctx_analyze' },
      { label: 'ctx_benchmark', href: '/docs/tools-benchmark' },
      { label: 'ctx_metrics', href: '/docs/tools-metrics' },
    ],
  },
  {
    title: 'Reference',
    items: [
      { label: 'Configuration', href: '/docs/configuration' },
      { label: 'Session Metrics', href: '/docs/dashboard' },
      { label: 'CLI', href: '/docs/cli' },
      { label: 'Token Cost Guide', href: '/docs/token-guide' },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:block">
  <nav class="sticky top-24 space-y-8">
    {sections.map(section => (
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/50 mb-3">{section.title}</h4>
        <ul class="space-y-1">
          {section.items.map(item => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block text-sm py-1.5 px-3 rounded-lg transition-all duration-300',
                  currentPath === item.href
                    ? 'text-accent bg-accent/8 border border-accent/10 font-medium'
                    : 'text-muted hover:text-text-bright hover:bg-surface-2'
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
