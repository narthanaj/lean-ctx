<section class="relative overflow-hidden grid-bg">
  <div class="orb w-[600px] h-[600px] bg-accent/20 top-[-150px] left-[5%]" style="animation-delay: 0s;"></div>
  <div class="orb w-[500px] h-[500px] bg-accent-2/15 top-[0px] right-[0%]" style="animation-delay: -7s;"></div>
  <div class="orb w-[350px] h-[350px] bg-accent-3/10 bottom-[5%] left-[40%]" style="animation-delay: -13s;"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-transparent to-bg pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-28 pb-24">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2.5 px-5 py-2 mb-8 rounded-full glass text-xs text-muted">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          Open Source · MIT · TypeScript
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-6">
          Your AI agent wastes tokens on context it already has.
          <span class="gradient-text">Stop it.</span>
        </h1>

        <p class="text-lg text-muted leading-relaxed mb-4">
          <strong class="text-text-bright">lean-ctx</strong> (<em>lean context</em>) is an MCP server that
          caches, compresses, and deduplicates every file read and CLI output
          before it reaches the LLM.
        </p>
        <p class="text-lg text-muted leading-relaxed mb-10">
          <strong class="text-text">Better reasoning. Longer sessions. Lower costs.</strong>
        </p>

        <!-- Stats -->
        <div class="flex flex-wrap gap-5 mb-10">
          <div class="flex items-center gap-2.5 px-5 py-3 rounded-xl glass">
            <span class="text-2xl font-extrabold gradient-text-accent">89–99%</span>
            <span class="text-xs text-muted leading-tight">tokens<br/>removed</span>
          </div>
          <div class="flex items-center gap-2.5 px-5 py-3 rounded-xl glass">
            <span class="text-2xl font-extrabold gradient-text">8</span>
            <span class="text-xs text-muted leading-tight">MCP<br/>tools</span>
          </div>
          <div class="flex items-center gap-2.5 px-5 py-3 rounded-xl glass">
            <span class="text-2xl font-extrabold gradient-text-accent">4+</span>
            <span class="text-xs text-muted leading-tight">editors<br/>supported</span>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href="/docs/getting-started" class="btn-glossy inline-flex items-center px-8 py-3.5 text-sm font-bold rounded-xl text-bg">
