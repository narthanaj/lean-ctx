{
  "name": "lean-ctx",
  "version": "0.5.0",
  "description": "Smart Context MCP Server — reduces LLM token consumption by 89-99% through caching, compression, and compact protocols. Works with Cursor, GitHub Copilot, Claude Code, and any MCP client.",
  "type": "module",
  "bin": {
    "lean-ctx": "./dist/cli.js",
    "lean-ctx-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "dashboard": "node dist/cli.js dashboard"
  },
  "keywords": [
    "mcp",
    "llm",
    "token-optimization",
    "cursor",
    "copilot",
    "claude",
    "context-compression",
    "ai-coding"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lean-ctx/lean-ctx"
  },
  "homepage": "https://lean-ctx.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "lean-ctx.config.example.json"
  ]
